DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Leave blank for local dev — a random secret is generated and persisted automatically.
# Set an explicit value (e.g. `openssl rand -hex 32`) before deploying to production.
JWT_SECRET=

# Optional — OCR handles handwriting much better with these set, but Tesseract.js
# (bundled, no key needed) is used automatically as a fallback if either is missing.
# Google Cloud Vision: console.cloud.google.com → enable the "Vision API" → Credentials → Create API key
GOOGLE_VISION_API_KEY=
# Mathpix (specialised for maths/science equations — used for method_and_answer questions
# when set, otherwise falls through to Vision/Tesseract): mathpix.com/ocr → dashboard → App Keys
MATHPIX_API_ID=
MATHPIX_API_KEY=

PORT=3001
NODE_ENV=development
# Only needed if the frontend is hosted on a different origin than this backend
# (e.g. Vercel frontend + Railway backend). Leave blank to allow any origin.
CORS_ORIGIN=
